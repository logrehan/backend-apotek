generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model detail_pembelian {
  id           BigInt    @id @default(autoincrement())
  id_obat      BigInt
  jumlah_beli  Int
  harga_beli   Float
  subtotal     Float
  id_pembelian BigInt
  created_at   DateTime? @default(now())
  updated_at   DateTime?

  obat         obat      @relation(fields: [id_obat], references: [id])
  pembelian    pembelian @relation(fields: [id_pembelian], references: [id])

  @@index([id_obat])
  @@index([id_pembelian])
}

model detail_penjualan {
  id           BigInt    @id @default(autoincrement())
  id_penjualan BigInt
  id_obat      BigInt
  jumlah_beli  Int
  harga_beli   Float
  subtotal     Int
  created_at   DateTime? @default(now())
  updated_at   DateTime?

  obat         obat       @relation(fields: [id_obat], references: [id])
  penjualan    penjualan  @relation(fields: [id_penjualan], references: [id])

  @@index([id_obat])
  @@index([id_penjualan])
}

model distributor {
  id               BigInt      @id @default(autoincrement())
  nama_distributor String
  telepon          String
  alamat           String
  created_at       DateTime?   @default(now())
  updated_at       DateTime?

  pembelian        pembelian[]
}

model jenis_obat {
  id         BigInt    @id @default(autoincrement())
  jenis      String
  deskripsi  String?
  created_at DateTime? @default(now())
  image_url  String?
  updated_at DateTime?

  obat       obat[]
}

model jenis_pengiriman {
  id             BigInt                       @id @default(autoincrement())
  jenis_kirim    jenis_pengiriman_jenis_kirim
  nama_ekspedisi String
  logo_ekspedisi String?
  created_at     DateTime?                    @default(now())
  updated_at     DateTime?

  penjualan      penjualan[]
}

model keranjang {
  id           BigInt    @id @default(autoincrement())
  id_pelanggan BigInt
  id_obat      BigInt
  jumlah_order Float
  harga        Float
  subtotal     Float
  created_at   DateTime? @default(now())
  updated_at   DateTime?

  obat         obat      @relation(fields: [id_obat], references: [id])
  pelanggan    pelanggan @relation(fields: [id_pelanggan], references: [id])

  @@index([id_obat])
  @@index([id_pelanggan])
}

model metode_bayar {
  id                BigInt      @id @default(autoincrement())
  metode_pembayaran String
  tempat_bayar      String
  no_rekening       String?
  url_logo          String?
  created_at        DateTime?   @default(now())
  updated_at        DateTime?

  penjualan         penjualan[]
}

model obat {
  id               BigInt             @id @default(autoincrement())
  nama_obat        String
  harga_jual       Int
  stok             Int
  id_jenis         BigInt
  created_at       DateTime?          @default(now())
  deskripsi_obat   String?
  foto1            String?
  foto2            String?
  foto3            String?
  updated_at       DateTime?

  detail_pembelian detail_pembelian[]
  detail_penjualan detail_penjualan[]
  keranjang        keranjang[]

  jenis_obat       jenis_obat @relation(fields: [id_jenis], references: [id])

  @@index([id_jenis])
}

model pelanggan {
  id             BigInt      @id @default(autoincrement())
  nama_pelanggan String
  email          String
  no_telp        String
  created_at     DateTime?   @default(now())
  updated_at     DateTime?
  alamat1        String
  alamat2        String?
  alamat3        String?
  foto           String?
  katasandi      String
  kodepos1       String
  kodepos2       String?
  kodepos3       String?
  kota1          String
  kota2          String?
  kota3          String?
  propinsi1      String
  propinsi2      String?
  propinsi3      String?
  url_ktp        String?

  keranjang      keranjang[]
  penjualan      penjualan[]
}

model pembelian {
  id               BigInt             @id @default(autoincrement())
  nonota           String
  tgl_pembelian    DateTime
  total_bayar      Float
  id_distributor   BigInt
  created_at       DateTime?          @default(now())
  updated_at       DateTime?

  detail_pembelian detail_pembelian[]

  distributor      distributor @relation(fields: [id_distributor], references: [id])

  @@index([id_distributor])
}

model pengiriman {
  id           BigInt                  @id @default(autoincrement())
  id_penjualan BigInt
  no_invoice   String
  tgl_kirim    DateTime
  tgl_tiba     DateTime?
  status_kirim pengiriman_status_kirim
  nama_kurir   String
  telpon_kurir String
  bukti_foto   String?
  keterangan   String?
  created_at   DateTime?               @default(now())
  updated_at   DateTime?

  penjualan    penjualan @relation(fields: [id_penjualan], references: [id])

  @@index([id_penjualan])
}

model penjualan {
  id                BigInt                 @id @default(autoincrement())
  id_metode_bayar   BigInt
  tgl_penjualan     DateTime
  url_resep         String?
  ongkos_kirim      Float
  biaya_app         Float
  total_bayar       Float
  status_order      penjualan_status_order
  keterangan_status String?
  id_jenis_kirim    BigInt
  id_pelanggan      BigInt
  created_at        DateTime?              @default(now())
  updated_at        DateTime?

  detail_penjualan  detail_penjualan[]
  pengiriman        pengiriman[]

  jenis_pengiriman  jenis_pengiriman @relation(fields: [id_jenis_kirim], references: [id])
  metode_bayar      metode_bayar     @relation(fields: [id_metode_bayar], references: [id])
  pelanggan         pelanggan        @relation(fields: [id_pelanggan], references: [id])

  @@index([id_jenis_kirim])
  @@index([id_metode_bayar])
  @@index([id_pelanggan])
}

model users {
  id                BigInt        @id @default(autoincrement())
  email             String        @unique
  password          String
  created_at        DateTime?     @default(now())
  updated_at        DateTime?
  email_verified_at DateTime?
  jabatan           users_jabatan
  name              String
  remember_token    String?
}

enum jenis_pengiriman_jenis_kirim {
  ekonomi
  kargo
  regular
  same_day
  standar
}

enum pengiriman_status_kirim {
  Sedang_Dikirim
  Tiba_Di_Tujuan
}

enum users_jabatan {
  admin
  apoteker
  karyawan
  kasir
  pemilik
}

enum penjualan_status_order {
  Menunggu_Konfirmasi
  Diproses
  Menunggu_Kurir
  Dibatalkan_Pembeli
  Dibatalkan_Penjual
  Bermasalah
  Selesai
}